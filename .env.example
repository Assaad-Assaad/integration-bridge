# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Odoo
ODOO_URL=http://odoo:8069
ODOO_DB=odoo
ODOO_USER_ID=2
ODOO_API_KEY=your-odoo-api-key

# FossBilling
FOSSBILLING_URL=http://fossbilling:80
FOSSBILLING_API_KEY=your-fossbilling-api-key

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@example.com

# Firebase
FIREBASE_CREDENTIALS_PATH=/app/firebase-key.json